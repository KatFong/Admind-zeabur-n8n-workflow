# Zeabur Variables for AdMind.ai n8n Meta Ads Agent
# Copy these into Zeabur Variables. Replace placeholders with real secrets.
# Do NOT commit real access tokens or API keys to GitHub.

N8N_PORT=5678
PORT=${WEB_PORT}
PASSWORD=replace_with_your_zeabur_password

N8N_PROTOCOL=https
WEBHOOK_URL=https://your-zeabur-domain/
GENERIC_TIMEZONE=Asia/Hong_Kong
TZ=Asia/Hong_Kong

TELEGRAM_BOT_TOKEN=replace_with_your_telegram_bot_token
TELEGRAM_CHAT_ID=1327792194

META_AD_ACCOUNT_ID=act_2073150323260144
META_ACCESS_TOKEN=replace_with_your_meta_access_token
META_GRAPH_API_VERSION=v20.0

OPENAI_API_KEY=replace_with_your_openai_api_key
META_AGENT_MODEL=gpt-4.1-mini
META_AGENT_DATE_PRESET=last_7d
META_AGENT_LIMIT=100

META_AGENT_PENDING_DIR=/data/meta_ads_agent_pending
META_EXECUTION_MODE=dry_run
