# Zeabur n8n environment variables for AdMind.ai Meta Ads Agent
# Do NOT commit real secrets to GitHub. Put real values in Zeabur Variables UI.

# n8n basic settings
N8N_HOST=${ZEABUR_WEB_DOMAIN}
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://${ZEABUR_WEB_DOMAIN}/
GENERIC_TIMEZONE=Asia/Hong_Kong
TZ=Asia/Hong_Kong

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_your_bot_token
TELEGRAM_CHAT_ID=1327792194

# Meta Ads
META_AD_ACCOUNT_ID=act_2073150323260144
META_ACCESS_TOKEN=replace_with_meta_access_token
META_GRAPH_API_VERSION=v20.0

# AI
OPENAI_API_KEY=replace_with_openai_api_key
META_AGENT_MODEL=gpt-4.1-mini
META_AGENT_DATE_PRESET=last_7d
META_AGENT_LIMIT=100

# Agent storage and execution safety
META_AGENT_PENDING_DIR=/data/meta_ads_agent_pending
META_EXECUTION_MODE=dry_run
